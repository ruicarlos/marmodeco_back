generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("GESTOR") // GESTOR | ADMIN
  active    Boolean  @default(true)
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects    Project[]
  budgets     Budget[]
  auditLogs   AuditLog[]
  kpiRecords  KPIRecord[]
}

model Company {
  id        String   @id @default(uuid())
  name      String
  cnpj      String?  @unique
  email     String?
  phone     String?
  address   String?
  plan      String   @default("BASIC") // BASIC | PRO | ENTERPRISE
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users      User[]
  projects   Project[]
  kpiRecords KPIRecord[]
  sellers    Seller[]
}

model Project {
  id          String   @id @default(uuid())
  name        String
  description String?
  clientName  String?
  clientEmail String?
  clientPhone String?
  status      String   @default("DRAFT") // DRAFT | IN_PROGRESS | COMPLETED | CANCELLED
  projectType String?  // RESIDENCIAL | COMERCIAL | INDUSTRIAL | OUTRO
  deadline    DateTime?
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  files    ProjectFile[]
  rooms    Room[]
  budgets  Budget[]
}

model ProjectFile {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  filename    String
  originalName String
  mimetype    String
  size        Int
  path        String
  processed   Boolean  @default(false)
  processedAt DateTime?
  createdAt   DateTime @default(now())

  rooms Room[]
}

model Room {
  id            String   @id @default(uuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fileId        String?
  file          ProjectFile? @relation(fields: [fileId], references: [id])
  name          String
  area          Float    @default(0) // m²
  perimeter     Float    @default(0) // m
  notes         String?
  isManual      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  budgetItems BudgetItem[]
}

model Material {
  id          String   @id @default(uuid())
  name        String
  type        String   // MARBLE | GRANITE | QUARTZITE | OTHER
  color       String?
  finish      String?  // POLISHED | BRUSHED | HONED | NATURAL
  thickness   Float?   // cm
  pricePerM2  Float    @default(0)
  stock       Float    @default(0) // m² disponível em estoque
  unit        String   @default("m²")
  active      Boolean  @default(true)
  imageUrl    String?
  description String?
  supplier    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  budgetItems BudgetItem[]
}

model Budget {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  sellerId    String?
  seller      Seller?  @relation(fields: [sellerId], references: [id])
  name        String
  status      String   @default("DRAFT") // DRAFT | PENDING | APPROVED | REJECTED
  totalArea   Float    @default(0)
  totalCost   Float    @default(0)
  laborCost   Float    @default(0)
  extraCost   Float    @default(0)
  discount    Float    @default(0)
  notes       String?
  validUntil  DateTime?
  approvedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items       BudgetItem[]
  adjustments BudgetAdjustment[]
  sale        Sale?
}

model Sale {
  id            String   @id @default(uuid())
  budgetId      String   @unique
  budget        Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  userId        String
  companyId     String?
  clientName    String?
  totalAmount   Float
  paymentMethod String   @default("PIX") // CARD | PIX | CASH | MIXED
  status        String   @default("PENDING") // PENDING | PAID | PARTIAL | CANCELLED
  notes         String?
  paidAt        DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  payments         SalePayment[]
  financialEntries FinancialEntry[]
}

model SalePayment {
  id        String    @id @default(uuid())
  saleId    String
  sale      Sale      @relation(fields: [saleId], references: [id], onDelete: Cascade)
  method    String    // CARD | PIX | CASH
  amount    Float
  paidAt    DateTime?
  createdAt DateTime  @default(now())
}

model FinancialEntry {
  id          String    @id @default(uuid())
  userId      String
  companyId   String?
  type        String    // RECEIVABLE | PAYABLE
  description String
  amount      Float
  dueDate     DateTime?
  paidAt      DateTime?
  status      String    @default("PENDING") // PENDING | PAID | OVERDUE | CANCELLED
  category    String?
  saleId      String?
  sale        Sale?     @relation(fields: [saleId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model BudgetAdjustment {
  id          String   @id @default(uuid())
  budgetId    String
  budget      Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  description String
  type        String   // COST | DISCOUNT
  valueType   String   // FIXED | PERCENT
  value       Float
  createdAt   DateTime @default(now())
}

model Seller {
  id         String   @id @default(uuid())
  name       String
  email      String?
  phone      String?
  commission Float    @default(0) // %
  active     Boolean  @default(true)
  companyId  String?
  company    Company? @relation(fields: [companyId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  budgets    Budget[]
}

model BudgetItem {
  id         String   @id @default(uuid())
  budgetId   String
  budget     Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  roomId     String
  room       Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  materialId String
  material   Material @relation(fields: [materialId], references: [id], onDelete: Restrict)
  area       Float    @default(0)
  quantity   Float    @default(0)
  unitPrice  Float    @default(0)
  subtotal   Float    @default(0)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model SubscriptionPlan {
  id            String   @id @default(uuid())
  name          String   @unique
  code          String   @unique // BASIC | PRO | ENTERPRISE
  price         Float
  maxUsers      Int
  maxProjects   Int
  maxStorage    Int      // GB
  features      String   // JSON array
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model KPIRecord {
  id                 String   @id @default(uuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id])
  companyId          String?
  company            Company? @relation(fields: [companyId], references: [id])
  type               String   // PRODUTIVIDADE | OEE
  period             DateTime // mês/ano de referência
  // Produtividade
  unidadesProduzidas Float?
  horasTrabalhadas   Float?
  numOperadores      Int?
  // OEE
  disponibilidade    Float?   // %
  desempenho         Float?   // %
  qualidade          Float?   // %
  // Resultado calculado
  resultado          Float    @default(0)
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  details   String?  // JSON
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
}
